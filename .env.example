# Interview Handbook - Environment Variables Template
# 이 파일은 템플릿입니다. 실제 API 키는 .env 파일을 새로 생성하여 작성하세요. (깃허브 업로드 금지)

# 1. Database 연결 설정
DB_HOST=postgres
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=password

# 2. 외부 AI API 키 설정
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# 3. SMTP 이메일 발송 계정 정보 설정
MAIL_USERNAME=your_gmail_account@gmail.com
MAIL_PASSWORD=your_gmail_app_password
